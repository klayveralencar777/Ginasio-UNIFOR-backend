
generator client {
  provider = "prisma-client-js"
  
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  cpf       String   @unique
  birthDate DateTime
  phone     String
  typeUser   TypeUser
  aluno       Aluno?
  funcionario Funcionario?
  estrangeiro Estrangeiro?
  
  scheduling  Scheduling[]
  createdAt   DateTime @default(now())
}

model Aluno {
  id          String   @id @default(uuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  matricula   String   @unique
  
  createdAt   DateTime @default(now())
}

model Funcionario {
  id          String   @id @default(uuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  matricula   String   @unique
  
  createdAt   DateTime @default(now())
}

model Estrangeiro {
  id          String   @id @default(uuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
}

model Scheduling {
  id        String   @id @default(uuid())

  userId    String
  user      User     @relation(fields: [userId], references: [id])
  place     String
  date      DateTime
  status    Status

  createdAt DateTime @default(now())
  


}


enum Status {
  PENDING
  COMPLETED
  CANCELLED
}


enum TypeUser {
  FUNCIONARIO
  ALUNO
  ESTRANGEIRO
}
