
generator client {
  provider = "prisma-client-js"
  
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  cpf       String   @unique
  birthDate DateTime
  phone     String
  role      Role     
  member    Member?
  scheduling Scheduling[]
  createdAt DateTime @default(now())
 
  
}


model Scheduling {
  id        String   @id @default(uuid())

  userId    String
  user      User     @relation(fields: [userId], references: [id])
  place     String
  date      DateTime
  status     Status

  createdAt DateTime @default(now())
  

}

enum Role {
  ADMIN
  USER
}

enum Status {
  PENDING
  COMPLETED
  CANCELLED
}

enum MemberType {
  STUDENT
  STAFF
}


model Member {
  id    String   @id @default(uuid())
  userId String @unique
  user    User   @relation(fields: [userId], references: [id])
  registration  String
  memberType MemberType
  createdAt DateTime @default(now())
 

}
